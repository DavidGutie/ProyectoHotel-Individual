<UserControl x:Class="HOTELINTERFAZ.Views.ClienteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HOTELINTERFAZ.Views"
             mc:Ignorable="d"
             Height="700" Width="1150">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gestión de Clientes"
                   Foreground="White"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>
            <Border Grid.Row="1"
                Background="{StaticResource BgPanel}"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,16">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="Nuevo" Style="{StaticResource AccentButton}" Click="Nuevo_Cliente_Click"/>
                        <Button Content="Editar" Style="{StaticResource DarkButton}" Click="Editar_Cliente_Click"/>
                        <Button Content="Eliminar" Style="{StaticResource DarkButton}" Click="Eliminar_Cliente_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBlock Text="Buscar DNI"
                                   Foreground="White"
                                   FontSize="23"
                                   FontWeight="Bold"
                                   Margin="0,5,10,16"/>
                        <TextBox x:Name="TxtBuscar"
                                 Width="280"
                                 Margin="0,0,10,0"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource DarkTextBox}"
                                 TextChanged="TxtBuscar_TextChanged"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            <DataGrid x:Name="DgClientes"
                  Grid.Row="2"
                  Style="{StaticResource DarkDataGrid}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowEditEnding="DgClientes_RowEditEnding"
                  ItemsSource="{Binding  ClienteView}"
                  SelectedItem="{Binding ClienteSeleccionado}">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="DNI"
                        Binding="{Binding DNI, UpdateSourceTrigger=PropertyChanged}"
                        Width="150"/>

                    <DataGridTextColumn Header="Nombre"
                        Binding="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                        Width="170"/>

                    <DataGridTextColumn Header="Email"
                        Binding="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                        Width="200"/>

                    <DataGridTextColumn Header="Fecha Nacimiento"
                        Binding="{Binding FechaNacimiento, StringFormat=dd/MM/yyyy, UpdateSourceTrigger=PropertyChanged}"
                        Width="160"/>

                    <DataGridTextColumn Header="Sexo"
                            Binding="{Binding Sexo, UpdateSourceTrigger=PropertyChanged}"
                            Width="70"/>
                     
                    <DataGridCheckBoxColumn Header="Vip"
                        Binding="{Binding Vip, UpdateSourceTrigger=PropertyChanged}"
                        Width="60"/>
                    
                    <DataGridTextColumn Header="Ciudad"
                                        Binding="{Binding Ciudad, UpdateSourceTrigger=PropertyChanged}"
                                        Width="120"/>
                </DataGrid.Columns>
                    
            </DataGrid>

        </Grid>
    </Grid>
</UserControl>
