<Window x:Class="HOTELINTERFAZ.Ventanas.BuscarReservasParaCancelarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar reservas para cancelar"
        Height="450"
        Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#3A3A3A">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="DNI:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       Foreground="White"/>
            <TextBox x:Name="txtDni"
                     Width="200"
                     Margin="0,0,10,0"/>
            <Button Content="Buscar"
                    Width="100"
                    Background="#E6C86E"
                    Foreground="Black"
                    Click="Buscar_Click2"/>
        </StackPanel>
        <DataGrid x:Name="dgReservas"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Background="#2A2A2A"
                  Foreground="Black">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="180"/>
                <DataGridTextColumn Header="Cliente"
                                    Binding="{Binding Cliente.Nombre}"
                                    Width="120"/>
                <DataGridTextColumn Header="Habitación"
                                    Binding="{Binding Habitacion.Numero}"
                                    Width="120"/>
                <DataGridTextColumn Header="Entrada"
                                    Binding="{Binding FechaEntrada, StringFormat=dd/MM/yyyy}"
                                    Width="120"/>
                <DataGridTextColumn Header="Salida"
                                    Binding="{Binding FechaSalida, StringFormat=dd/MM/yyyy}"
                                    Width="120"/>
                <DataGridCheckBoxColumn Header="Cancelada"
                                        Binding="{Binding Cancelacion}"
                                        Width="100"/>
                <DataGridTemplateColumn Header="Acción" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Cancelar"
                                    Background="#E6C86E"
                                    Foreground="Black"
                                    Click="Cancelar_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
