<Window x:Class="HOTELINTERFAZ.Ventanas.HistorialReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial de reserva"
        Height="500"
        Width="950"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#2B2B2B">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Border Background="{StaticResource BgMain}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TxtTitulo"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1"
                          Style="{StaticResource DarkDataGrid}"
                          ItemsSource="{Binding Historial}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          BorderThickness="0"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Acción"
                                            Binding="{Binding AccionTexto}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Fecha y hora"
                                            Binding="{Binding Timestamp, StringFormat=dd/MM/yyyy HH:mm}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Resumen"
                                            Binding="{Binding ResumenCambio}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>