<Window x:Class="HOTELINTERFAZ.Ventanas.HistorialReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HOTELINTERFAZ.Ventanas"
        mc:Ignorable="d"
        Title="HistorialReservaWindow" Height="450" Width="800">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BgMain}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitulo"
                   Foreground="White"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <DataGrid Grid.Row="1"
                  Style="{StaticResource DarkDataGrid}"
                  ItemsSource="{Binding Historial}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Acción"
                                    Binding="{Binding AccionTexto}"
                                    Width="170"/>

                <DataGridTextColumn Header="Actor"
                                    Binding="{Binding ActorTexto}"
                                    Width="100"/>

                <DataGridTextColumn Header="Fecha y hora"
                                    Binding="{Binding Timestamp, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="150"/>

                <DataGridTextColumn Header="Resumen"
                                    Binding="{Binding ResumenCambio}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
