<Window x:Class="HOTELINTERFAZ.Ventanas.HabitacionCrudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HOTELINTERFAZ.Ventanas"
        mc:Ignorable="d"
        Title="HabitacionCrudWindow" Height="720" Width="620">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Border Background="{StaticResource BgPanel}" CornerRadius="12" Padding="18" Margin="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Datos de la habitación"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Número" Foreground="White"/>
                        <TextBox Text="{Binding Numero}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,12"/>

                        <TextBlock Text="Tipo" Foreground="White"/>
                        <TextBox Text="{Binding Tipo}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,12"/>

                        <TextBlock Text="Descripción" Foreground="White"/>
                        <TextBox Text="{Binding Descripcion}" Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" Height="70" Margin="0,6,0,12"/>

                        <TextBlock Text="Máx. ocupantes" Foreground="White"/>
                        <TextBox Text="{Binding MaxOcupantes}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,12"/>

                        <TextBlock Text="Precio por noche" Foreground="White"/>
                        <TextBox Text="{Binding PrecioNoche}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,12"/>

                        <TextBlock Text="Rate" Foreground="White"/>
                        <TextBox Text="{Binding Rate}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox Content="Disponible" IsChecked="{Binding Disponible}" Foreground="White" Margin="0,0,18,0"/>
                            <CheckBox Content="Oferta" IsChecked="{Binding Oferta}" Foreground="White"/>
                        </StackPanel>

                        <TextBlock Text="Mascotas" Foreground="White" FontWeight="Bold" Margin="0,4,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox Content="Admite mascotas"
                                      IsChecked="{Binding AdmiteMascotas}"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,0,18,0"/>
                            <StackPanel Width="190" Margin="0,0,12,0">
                                <TextBlock Text="Suplemento/noche" Foreground="White"/>
                                <TextBox Text="{Binding SuplementoMascotasNoche}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Width="130">
                                <TextBlock Text="Máx. mascotas" Foreground="White"/>
                                <TextBox Text="{Binding MaxMascotas}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Política de mascotas" Foreground="White"/>
                        <TextBox Text="{Binding PoliticaMascotas}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,12"/>

                        <TextBlock Text="Amenities" Foreground="White" FontWeight="Bold" Margin="0,4,0,8"/>
                        <ItemsControl x:Name="AmenityCategoriesItems" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#4A4A4A" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Category}" Foreground="#E6C86E" FontWeight="Bold" Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding DisplayName}"
                                                                  IsChecked="{Binding IsSelected}"
                                                                  Foreground="White"
                                                                  Width="170"
                                                                  Margin="0,0,8,8"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Servicios (separados por coma o punto y coma)" Foreground="White"/>
                        <TextBox Text="{Binding ServiciosTexto}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,12"/>

                        <TextBlock Text="Imagen (URL)" Foreground="White"/>
                        <TextBox Text="{Binding Imagen}" Style="{StaticResource DarkTextBox}" Margin="0,6,0,12"/>

                        <Border CornerRadius="10" ClipToBounds="True" Margin="0,0,0,6">
                            <Image Source="{Binding Imagen}" Height="160" Stretch="UniformToFill"/>
                        </Border>

                        <TextBlock Text="Tip: puedes pegar una URL de Wikimedia (Special:FilePath/...)" Foreground="#C8C8C8" FontSize="12"/>

                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="Cancelar" Style="{StaticResource DarkButton}" Width="110" Margin="0,0,10,0" Click="Cancelar_Click"/>
                    <Button Content="Guardar" Style="{StaticResource AccentButton}" Width="110" Click="Guardar_Click"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>

</Window>
