<Window x:Class="HOTELINTERFAZ.Ventanas.NuevaReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Crear Reserva"
        Height="440"
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#3A3A3A"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="DNI del cliente" Foreground="White"/>
            <ComboBox x:Name="DniComboBox"
                      DisplayMemberPath="DNI"
                      SelectedItem="{Binding ClienteSeleccionado, Mode=TwoWay}"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      TextSearch.TextPath="DNI"
                      StaysOpenOnEdit="True"/>

            <TextBlock Text="Fecha de entrada" Foreground="White"/>
            <DatePicker x:Name="FechaEntradaPicker"
                        DisplayDateStart="{x:Static sys:DateTime.Now}" />

            <TextBlock Text="Fecha de salida" Foreground="White"/>
            <DatePicker x:Name="FechaSalidaPicker"
                        DisplayDateStart="{x:Static sys:DateTime.Now}" />

            <TextBlock Text="Número de personas" Foreground="White"/>
            <TextBox x:Name="TextBoxPersonas"/>

            <TextBlock Text="Habitación" Foreground="White"/>
            <ComboBox x:Name="ComboBoxHabitacion"
                      ItemsSource="{Binding HabitacionesDisponibles}" 
                      DisplayMemberPath="Numero"
                      SelectedItem="{Binding HabitacionSeleccionada, Mode=TwoWay}"
                      SelectionChanged="ComboBoxHabitacion_SelectionChanged" />

            <CheckBox x:Name="CheckMascota"
                      Content="Incluye mascota"
                      Foreground="White"
                      Margin="0,12,0,0"
                      Checked="Mascota_Changed"
                      Unchecked="Mascota_Changed"/>

            <TextBlock Text="Número de mascotas" Foreground="White"/>
            <TextBox x:Name="TextBoxMascotas"
                     Text="0"
                     IsEnabled="False"/>

            <TextBlock x:Name="TxtSuplementoMascotas"
                       Text=""
                       Foreground="#E6C86E"
                       Margin="0,6,0,0"/>

            <Button x:Name="GuardarButton"
                    Content="Crear"
                    Margin="0,20,0,0"
                    Click="Crear_Click"
                    Background="#E6C86E"/>

            <Button Content="Cancelar"
                    Margin="0,10,0,0"
                    Click="Cancelar_Click"
                    Background="#E6C86E"/>
        </StackPanel>
    </Grid>
</Window>
