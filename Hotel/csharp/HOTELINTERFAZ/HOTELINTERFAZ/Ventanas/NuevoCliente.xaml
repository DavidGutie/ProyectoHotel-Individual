<Window x:Class="HOTELINTERFAZ.Ventanas.NuevoCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:HOTELINTERFAZ.Ventanas"
        mc:Ignorable="d"
        Title="NuevoCliente" Height="400" Width="400"
        Background="#3A3A3A">
    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Nombre"
                       Foreground="White"/>
            <TextBox Text="{Binding NombreNuevo}" />

            <TextBlock Text="DNI"
                       Foreground="White"/>
            <TextBox Text="{Binding DniNuevo}" />

            <TextBlock Text="Email"
                       Foreground="White"/>
            <TextBox Text="{Binding EmailNuevo}" />

            <TextBlock Text="Password"
                       Foreground="White"/>
            <PasswordBox x:Name="PasswordBox"/>

            <DatePicker SelectedDate="{Binding FechaNacimientoNuevo}" />

            <TextBlock Text="Sexo"
                       Foreground="White"/>
            <ComboBox SelectedValue="{Binding SexoNuevo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="Masculino" Tag="M"/>
                <ComboBoxItem Content="Femenino" Tag="F"/>
                <ComboBoxItem Content="Otro" Tag="X"/>
            </ComboBox>

            <CheckBox Content="VIP"
                      IsChecked="{Binding vipNuevo}"
                      Foreground="White"
                      Margin="0,5,0,0"/>
            
            <TextBlock Text="Ciudad"
                       Foreground="White"/>
            <TextBox Text="{Binding ciudadNuevo}" 
                     Margin="0,0,0,10"/>

            <Button Content="Seleccionar Foto"
                    Click="SeleccionarFoto_Click"
                    Background="#E6C86E"/>

            <Button Content="Crear Empleado"
                    Margin="0,20,0,0"
                    Click="CrearCliente_Click"
                    Background="#E6C86E"/>

        </StackPanel>
    </Grid>
</Window>
