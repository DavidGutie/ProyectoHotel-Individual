<Window x:Class="HOTELINTERFAZ.Ventanas.AmenitiesCatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catálogo de amenities"
        Height="560"
        Width="760"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Border Background="{StaticResource BgPanel}" CornerRadius="12" Padding="18" Margin="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Catálogo de amenities"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,14"/>

                <DataGrid x:Name="DgAmenities"
                          Grid.Row="1"
                          Style="{StaticResource DarkDataGrid}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          SelectionChanged="DgAmenities_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Icono" Binding="{Binding Icon}" Width="90"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Categoría" Binding="{Binding Category}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Icono" Foreground="White"/>
                        <TextBox x:Name="TxtIcono" Style="{StaticResource DarkTextBox}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Nombre" Foreground="White"/>
                        <TextBox x:Name="TxtNombre" Style="{StaticResource DarkTextBox}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Categoría" Foreground="White"/>
                        <TextBox x:Name="TxtCategoria" Style="{StaticResource DarkTextBox}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Nuevo" Style="{StaticResource DarkButton}" Click="Nuevo_Click"/>
                        <Button Content="Guardar" Style="{StaticResource AccentButton}" Click="Guardar_Click"/>
                        <Button Content="Eliminar" Style="{StaticResource DarkButton}" Click="Eliminar_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
