<Window x:Class="HOTELINTERFAZ.Ventanas.EditarEmpleado"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:HOTELINTERFAZ.Ventanas"
        mc:Ignorable="d"
        Title="EditarEmpleado" Height="450" Width="400">
    
    
    <ScrollViewer Background="#3A3A3A">
        <StackPanel Margin="20">

            <Image Height="120"
                   Width="120"
                   Source="{Binding FotoUrlCompleta}"
                   Stretch="UniformToFill"/>

            <Button Content="Cambiar Foto"
                    Click="SeleccionarFoto_Click"
                    Background="#E6C86E"/>

            <TextBlock Text="Nombre"
                       Foreground="White"/>
            <TextBox Text="{Binding NombreNuevo}"/>

            <TextBlock Text="Email"
                       Foreground="White"/>
            <TextBox Text="{Binding EmailNuevo}"/>
            
            <TextBlock Text="Contraseña (Opcional)"
                       Foreground="White"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"/>

            <DatePicker SelectedDate="{Binding FechaNacimientoNuevo}"/>

            <TextBlock Text="Sexo"
                       Foreground="White"/>
            <ComboBox SelectedValue="{Binding SexoNuevo, Mode=TwoWay}"
                      SelectedValuePath="Tag">

                <ComboBoxItem Content="Masculino" Tag="M"/>
                <ComboBoxItem Content="Femenino" Tag="F"/>
                <ComboBoxItem Content="Otro" Tag="X"/>

            </ComboBox>

            <CheckBox Content="Administrador"
                      IsChecked="{Binding AdministradorNuevo}"
                      Foreground="White"/>

            <Button Content="Guardar Cambios"
                    Margin="0,20,0,0"
                    Click="GuardarCambios_Click"
                    Background="#E6C86E"/>

        </StackPanel>
    </ScrollViewer>
</Window>
