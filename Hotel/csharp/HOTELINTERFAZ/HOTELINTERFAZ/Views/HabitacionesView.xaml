<UserControl x:Class="HOTELINTERFAZ.Views.HabitacionesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HOTELINTERFAZ.Views"
        mc:Ignorable="d"
        Height="700" Width="1150">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gestión de habitaciones"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>

            <Border Grid.Row="1"
                    Background="{StaticResource BgPanel}"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,16">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="Nueva" Style="{StaticResource AccentButton}" Click="Nueva_Click"/>
                        <Button Content="Editar" Style="{StaticResource DarkButton}" Click="Editar_Click"/>
                        <Button Content="Eliminar" Style="{StaticResource DarkButton}" Click="Eliminar_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBox x:Name="TxtBuscar"
                                 Width="280"
                                 Margin="0,0,10,0"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource DarkTextBox}"/>
                        <Button Content="Buscar" Style="{StaticResource AccentButton}" Click="Buscar_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <DataGrid x:Name="DgHabitaciones"
                Grid.Row="2"
				Style="{StaticResource DarkDataGrid}"
				AutoGenerateColumns="False"
				CanUserAddRows="False"
				IsReadOnly="True"
				SelectionMode="Single"
				SelectionUnit="FullRow">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nº"
                            Binding="{Binding Numero, UpdateSourceTrigger=PropertyChanged}"
                            Width="80"/>

                    <DataGridTextColumn Header="Tipo"
                            Binding="{Binding Tipo, UpdateSourceTrigger=PropertyChanged}"
                            Width="160"/>

                    <DataGridTextColumn Header="Descripción"
							Binding="{Binding Descripcion}"
							Width="260"/>

                    <DataGridTextColumn Header="Capacidad"
                            Binding="{Binding MaxOcupantes, UpdateSourceTrigger=PropertyChanged}"
                            Width="140"/>

                    <DataGridTextColumn Header="Precio/Noche"
                            Binding="{Binding PrecioNoche, UpdateSourceTrigger=PropertyChanged}"
                            Width="160"/>

                    <DataGridTextColumn Header="Servicios"
							Binding="{Binding ServiciosTexto}"
							Width="240"/>

                    <DataGridTemplateColumn Header="Imagen" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image Source="{Binding Imagen}"
										   Height="70"
										   Width="120"
										   Stretch="UniformToFill"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridCheckBoxColumn Header="Estado"
                                Binding="{Binding Disponible, UpdateSourceTrigger=PropertyChanged}"
                                Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

        </Grid>
    </Grid>
</UserControl>
