<UserControl x:Class="HOTELINTERFAZ.Views.FacturasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="700"
             Width="1300">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgMain}" Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gestión de facturas"
                   Foreground="White"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="1"
                Background="{StaticResource BgPanel}"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="Actualizar"
                                Style="{StaticResource AccentButton}"
                                Click="Actualizar_Click"/>

                        <Button Content="Descargar PDF"
                                Style="{StaticResource DarkButton}"
                                Click="Descargar_Click"/>

                        <Button Content="Reenviar email"
                                Style="{StaticResource DarkButton}"
                                Click="Reenviar_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBox Width="280"
                                 Margin="0,0,10,0"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource DarkTextBox}"
                                 Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Margin="0,0,8,0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Config.NombreHotel, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBox Grid.Column="1"
                             Margin="0,0,8,0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Config.Cif, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBox Grid.Column="2"
                             Margin="0,0,8,0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Config.Direccion, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBox Grid.Column="3"
                             Margin="0,0,8,0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Config.Email, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBox Grid.Column="4"
                             Margin="0,0,8,0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Config.Telefono, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Grid.Column="5"
                            Content="Guardar cabecera"
                            Style="{StaticResource AccentButton}"
                            Click="GuardarConfig_Click"/>
                </Grid>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  Style="{StaticResource DarkDataGrid}"
                  ItemsSource="{Binding FacturasView}"
                  SelectedItem="{Binding FacturaSeleccionada, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Factura" Binding="{Binding InvoiceNumber}" Width="150"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding InvoiceIssuedAt, StringFormat=dd/MM/yyyy}" Width="110"/>
                <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente.Nombre}" Width="180"/>
                <DataGridTextColumn Header="DNI" Binding="{Binding Cliente.Dni}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Cliente.Email}" Width="210"/>
                <DataGridTextColumn Header="Habitación" Binding="{Binding Habitacion.Numero}" Width="100"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding Habitacion.Tipo}" Width="130"/>
                <DataGridTextColumn Header="Entrada" Binding="{Binding FechaEntrada, StringFormat=dd/MM/yyyy}" Width="105"/>
                <DataGridTextColumn Header="Salida" Binding="{Binding FechaSalida, StringFormat=dd/MM/yyyy}" Width="105"/>
                <DataGridTextColumn Header="Total" Binding="{Binding PrecioTotal, StringFormat={}{0:F2} €}" Width="105"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
