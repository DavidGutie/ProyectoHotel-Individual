<UserControl x:Class="HOTELINTERFAZ.Views.ReservasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HOTELINTERFAZ.ViewModels"
             Height="700"
             Width="1300">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gestión de reservas"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>

            <Border Grid.Row="1"
                    Background="{StaticResource BgPanel}"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,16">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="Nueva"
                                Style="{StaticResource AccentButton}"
                                Click="NuevaReserva_Click"/>

                        <Button Content="Modificar"
                                Style="{StaticResource DarkButton}"
                                Click="Modificar_Click"/>

                        <Button Content="Cancelar"
                                Style="{StaticResource DarkButton}"
                                Click="Cancelar_Click"/>

                        <Button Content="Eliminar"
                                Style="{StaticResource DarkButton}"
                                Click="Eliminar_Click"/>

                        <Button Content="Historial"
                                Style="{StaticResource DarkButton}"
                                Click="Historial_Click"/>

                        <Button Content="Registrar pago"
                                Style="{StaticResource DarkButton}"
                                Click="RegistrarPago_Click"/>

                        <Button Content="Añadir extra"
                                Style="{StaticResource DarkButton}"
                                Click="AgregarExtra_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBox Width="220"
                                 Margin="0,0,10,0"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource DarkTextBox}"
                                 Text="{Binding FiltroDni, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="Buscar"
                                Style="{StaticResource AccentButton}"
                                Click="Buscar_Click"/>

                        <CheckBox Content="Mostrar solo activas"
                                  Foreground="White"
                                  Margin="16,0,0,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding MostrarSoloActivas, Mode=TwoWay}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Text="{Binding MensajeError}"
                       Foreground="#FFFF8A8A"
                       FontWeight="SemiBold"
                       Margin="4,0,4,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TieneError}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <DataGrid Grid.Row="3"
                      Style="{StaticResource DarkDataGrid}"
                      ItemsSource="{Binding ReservasView}"
                      SelectedItem="{Binding ReservaSeleccionada, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="155"/>
                    <DataGridTextColumn Header="DNI" Binding="{Binding Cliente.Dni}" Width="125"/>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente.Nombre}" Width="170"/>
                    <DataGridTextColumn Header="Habitación" Binding="{Binding Habitacion.Numero}" Width="100"/>
                    <DataGridTextColumn Header="Entrada" Binding="{Binding FechaEntrada, StringFormat=dd/MM/yyyy}" Width="105"/>
                    <DataGridTextColumn Header="Salida" Binding="{Binding FechaSalida, StringFormat=dd/MM/yyyy}" Width="105"/>
                    <DataGridTextColumn Header="Personas" Binding="{Binding Personas}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Mascota" Binding="{Binding IncluyeMascota}" Width="80"/>
                    <DataGridTextColumn Header="Supl. mascota" Binding="{Binding ImporteSuplementoMascota, StringFormat={}{0:F2} €}" Width="115"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding PrecioTotal, StringFormat={}{0:F2} €}" Width="105"/>
                    <DataGridTextColumn Header="Factura" Binding="{Binding InvoiceNumber}" Width="145"/>
                    <DataGridTextColumn Header="Fecha factura" Binding="{Binding InvoiceIssuedAt, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridCheckBoxColumn Header="Cancelada" Binding="{Binding Cancelacion}" Width="95"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
