<UserControl x:Class="HOTELINTERFAZ.Views.ResenasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HOTELINTERFAZ.ViewModels"
             Height="700"
             Width="1150">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:ResenasViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource BgMain}">
        <Grid Margin="22">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gestión de reseñas"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>

            <Border Grid.Row="1"
                    Background="{StaticResource BgPanel}"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,16">

                <DockPanel LastChildFill="False">

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="Eliminar"
                                Style="{StaticResource DarkButton}"
                                Click="Eliminar_Click"/>
                    </StackPanel>

                </DockPanel>
            </Border>

            <DataGrid Grid.Row="2"
                      Style="{StaticResource DarkDataGrid}"
                      ItemsSource="{Binding Resenas}"
                      SelectedItem="{Binding ResenaSeleccionada, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Reserva"
                                        Binding="{Binding ReservaId}"
                                        Width="160"/>

                    <DataGridTextColumn Header="DNI"
                                        Binding="{Binding Cliente.Dni}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Habitación"
                                        Binding="{Binding HabitacionId}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Puntuación"
                                        Binding="{Binding Puntuacion}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Comentario"
                                        Binding="{Binding Comentario}"
                                        Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>
    </Grid>
</UserControl>